# App
PORT=4000
# Nest API ning ochiq HTTPS manzili (Telegram «Qabul qilish» /internal/telegram).
# Vercel/sayt domeni EMAS — Railway/Render’dagi API servis URL (masalan *.up.railway.app).
# Tekshiruv: brauzerda GET {PUBLIC_API_URL}/internal/telegram/ping → {"ok":true,...}
PUBLIC_API_URL=https://your-api.example.com
# TELEGRAM_API_CALLBACK_BASE_URL=https://your-api.example.com
# Telegram HMAC (worker + API bir xil): bo‘lmasa JWT_SECRET ishlatiladi
# TELEGRAM_ORDER_HMAC_SECRET=...

# Prisma 7: primary URL for CLI (migrations). App runtime also reads DATABASE_URL in code.
# Supabase: use pooled `?pgbouncer=true` (or pooler host) for the Nest app; keep a direct session URL as DIRECT_URL.
DATABASE_URL=postgresql://...
# Direct session URL (Supabase) for Prisma migrations.
DIRECT_URL=postgresql://...

# Supabase Storage (optional — without these, admin upload uses local /uploads)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=food-images

# CORS: comma-separated browser origins, or single FRONTEND_ORIGIN
# CORS_ORIGINS=https://www.minut-ka.uz,https://minut-ka.uz
# FRONTEND_ORIGIN=https://www.minut-ka.uz

# Resilience / observability (optional)
REQUEST_TIMEOUT_MS=25000
PRISMA_SLOW_QUERY_MS=500
ADMIN_SLOW_REQUEST_MS=800
# Archive retention window in days (restaurant archive + cleanup)
ARCHIVE_RETENTION_DAYS=30

# Auth token TTL (seconds)
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000
