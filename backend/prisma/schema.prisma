// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  email    String     @unique
  phone    String?    @unique
  name     String
  password String
  role     UserRole
  status   UserStatus @default(ACTIVE)

  addresses   Address[]
  orders      Order[]
  restaurants Restaurant[] @relation("RestaurantAdmins")
  courier     Courier?
}

model Address {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  label     String?
  street    String
  city      String
  details   String?
  latitude  Float
  longitude Float

  user   User   @relation(fields: [userId], references: [id])
  userId String

  orders Order[]
}

model Restaurant {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name        String
  description String?
  logoUrl     String?
  coverUrl    String?

  address   String
  latitude  Float
  longitude Float

  minOrderTotal   Decimal @default(0)
  deliveryFee     Decimal @default(0)
  deliveryRadiusM Int     @default(3000)

  rating   Float   @default(0)
  isActive Boolean @default(true)
  isSupermarket Boolean @default(false)
  isFeatured Boolean @default(false)
  featuredSortOrder Int @default(0)
  platformFeePercent Float @default(10)
  platformFeeClearedAt DateTime?
  telegramChatId     String?

  admins     User[]     @relation("RestaurantAdmins")
  categories Category[]
  dishes     Dish[]
  orders     Order[]
}

model Category {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name      String
  sortOrder Int    @default(0)

  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  restaurantId String

  dishes Dish[]
}

model Dish {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name        String
  description String?
  price       Decimal
  imageUrl    String?
  isAvailable Boolean @default(true)
  isHit       Boolean @default(false)
  isNew       Boolean @default(false)

  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  restaurantId String

  category   Category? @relation(fields: [categoryId], references: [id])
  categoryId String?

  orderItems OrderItem[]
}

model Order {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  status  OrderStatus @default(NEW)
  comment String?

  cancelReason String?
  cancelledBy  OrderStatusActor?
  cancelledAt  DateTime?

  customer   User   @relation(fields: [customerId], references: [id])
  customerId String

  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  restaurantId String

  address   Address @relation(fields: [addressId], references: [id])
  addressId String

  items OrderItem[]

  subtotal    Decimal
  deliveryFee Decimal
  serviceFee  Decimal
  total       Decimal

  payment Payment?

  courier   Courier? @relation(fields: [courierId], references: [id])
  courierId String?

  deliveryTrackings DeliveryTracking[]

  statusHistory OrderStatusHistory[]
}

model OrderStatusHistory {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  order    Order  @relation(fields: [orderId], references: [id])
  orderId  String

  oldStatus OrderStatus
  newStatus OrderStatus

  changedBy OrderStatusActor
}

model OrderItem {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  order   Order  @relation(fields: [orderId], references: [id])
  orderId String

  dish   Dish   @relation(fields: [dishId], references: [id])
  dishId String

  quantity Int     @default(1)
  price    Decimal
}

model Courier {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id])
  userId String @unique

  status CourierStatus @default(OFFLINE)

  orders Order[]
}

model DeliveryTracking {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  order   Order  @relation(fields: [orderId], references: [id])
  orderId String

  status DeliveryStatus
  note   String?
}

model Payment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  provider   String
  externalId String?
  amount     Decimal
  currency   String        @default("RUB")
  status     PaymentStatus @default(PENDING)
  method     PaymentMethod

  order   Order  @relation(fields: [orderId], references: [id])
  orderId String @unique
}

model Product {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name        String
  description String?
  price       Decimal
  unit        String  @default("dona")
  imageUrl    String?

  category   ProductCategory? @relation(fields: [categoryId], references: [id])
  categoryId String?
}

model Banner {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  title    String
  text     String?
  imageUrl String?

  ctaLabel String?
  ctaHref  String?

  sortOrder Int     @default(0)
  isActive Boolean @default(true)
}

model ProductCategory {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name      String
  imageUrl  String?
  sortOrder Int     @default(0)
  isActive  Boolean @default(true)

  products Product[]
}

model PushSubscription {
  id        Int      @id @default(autoincrement())
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

model PromoCode {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  code        String  @unique
  description String?

  discountType PromoDiscountType
  amount       Decimal

  startsAt DateTime?
  endsAt   DateTime?

  maxUses   Int?
  usedCount Int  @default(0)

  isActive Boolean @default(true)
}

enum UserRole {
  CUSTOMER
  RESTAURANT_ADMIN
  PLATFORM_ADMIN
  COURIER
}

enum UserStatus {
  ACTIVE
  BLOCKED
}

enum OrderStatus {
  NEW
  ACCEPTED
  READY
  ON_THE_WAY
  DONE
  CANCELLED
}

enum OrderStatusActor {
  ADMIN
  COURIER
}

enum CourierStatus {
  OFFLINE
  IDLE
  ON_DELIVERY
}

enum DeliveryStatus {
  ASSIGNED
  PICKED_UP
  NEARBY
  DELIVERED
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  CARD
  CASH
}

enum PromoDiscountType {
  PERCENT
  FIXED
}

model Visit {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
}
